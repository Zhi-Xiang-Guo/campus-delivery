.comment-page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.nav-bar {
  background: #409EFF;
  padding: calc(6rpx + env(safe-area-inset-top)) 30rpx 18rpx;
  display: flex;
  align-items: center;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
  height: calc(96rpx + env(safe-area-inset-top));
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
}

.back-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.nav-title {
  color: #fff;
  font-size: 34rpx;
  flex: 1;
  text-align: center;
  margin-right: 60rpx;
  line-height: 60rpx;
  margin-top: 2rpx;
}

.comment-content {
  padding: 20rpx;
  margin-top: calc(96rpx + env(safe-area-inset-top));
}

.section-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
}

/* 菜品 */
.order-dishes {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.dish-scroll {
  white-space: nowrap;
  padding: 10rpx 0;
}

.dish-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  width: 140rpx;
}

.dish-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.dish-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 120rpx;
  text-align: center;
}

/* 评分 */
.score-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.star-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 4rpx;
}

.star-wrapper {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff7ec;
}

.star {
  font-size: 60rpx;
  color: #d7dbe3;
  line-height: 1;
}

.star.active {
  color: #ffb400;
}

.score-tip-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.score-text {
  font-size: 30rpx;
  color: #ff8a00;
  font-weight: 600;
}

.score-desc {
  font-size: 24rpx;
  color: #8a94a6;
  margin-left: 16rpx;
}

/* 评价内容 */
.content-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 10rpx;
}

/* 图片 */
.image-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 0 12rpx 0 12rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 提交按钮 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #409EFF;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  text-align: center;
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}

.submit-btn::after {
  border: none;
}
